# Copy to .env and fill in. All values are optional except DB_PASSWORD (has a default).
# docker compose -f deploy/docker-compose.yml --env-file deploy/.env up --build

# Postgres password (defaults to "apiguard" if unset).
DB_PASSWORD=apiguard

# GitHub PAT with repo + pull_requests scope — enables PR comments, reviewer requests, spec fetch.
# Leave blank to run the server in "log only" mode (it prints what it would do).
GITHUB_TOKEN=

# Shared secret configured on the GitHub webhook (HMAC verification). Blank = verification disabled.
GITHUB_WEBHOOK_SECRET=

# Slack Incoming Webhook URL for breaking-change notifications. Blank = disabled.
SLACK_WEBHOOK_URL=

# For webhook mode: which spec file to diff on each PR, and the API name for blast-radius matching.
APIGUARD_WEBHOOK_SPEC_PATH=openapi.yaml
APIGUARD_WEBHOOK_API_NAME=orders-api

# URL the browser uses to reach the API (must be reachable from the user's browser, not the container).
APIGUARD_API=http://localhost:8080
